<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".PesquisaProblemasActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_margin="30dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/problemas_txt_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textSize="30sp"
            android:text="@string/problemas_txt_titulo" />

        <ListView
            android:id="@+id/problemas_lista"
            android:layout_width="match_parent"
            android:layout_height="510dp"
            android:layout_marginBottom="30dp"
            android:dividerHeight="3dp"
            android:layout_marginTop="40dp" >

        </ListView>

        <Button
            android:id="@+id/problemas_btn_confirmar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="90dp"
            android:layout_marginEnd="90dp"
            android:text="@string/btn_confirmar" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>