<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MenuPesquisasActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_margin="30dp"
        android:paddingTop="100dp"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp">

        <TextView
            android:id="@+id/pesquisa_txt_eleicao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginBottom="10dp"
            android:textStyle="bold"
            android:textSize="30sp"
            android:text="@string/pesquisas_txt_eleicao" />

        <TextView
            android:id="@+id/pesquisa_txt_pesquisa"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginBottom="50dp"
            android:textStyle="bold"
            android:textSize="30sp"
            android:text="@string/pesquisas_txt_pesquisas" />

        <Button
            android:id="@+id/pesquisa_btn_estimulada"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="50dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:text="@string/pesquisas_btn_estimulada" />

        <Button
            android:id="@+id/pesquisa_btn_espontanea"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="50dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:text="@string/pesquisas_btn_espontanea" />

        <Button
            android:id="@+id/pesquisa_btn_finalizar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:text="@string/pesquisas_btn_finalizar" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>